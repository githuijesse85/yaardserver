# Yaard Backend Environment Variables

# Database
DATABASE_URL=postgresql://postgres.wtlssqoatiqfgckooyqo:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Set to false when using Supabase transaction pooler (port 6543) or any self-signed cert.
# This eliminates the "self-signed certificate" warning in the admin panel and logs.
# Set to true only if your DB uses a valid CA-signed certificate on a direct connection.
DB_SSL_REJECT_UNAUTHORIZED=false

# Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Admin panel
# `ADMIN_SECRET` is used for the admin login password.
# Use `JWT_SECRET` for all JWT signing and verification (admin and user tokens).
ADMIN_SECRET=your_strong_admin_password_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Alternative optional value
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx

# Email
EMAIL_USER=info@example.com
EMAIL_PASS=your_smtp_password
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465

# App URL
APP_URL=https://yaardserver.netlify.app

# Local env loader (optional)
ENV_PATH=.env
