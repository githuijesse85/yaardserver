# Yaard Production Environment Variables
# Copy this to your Netlify deployment environment variables

# ================================================
# ADMIN AUTHENTICATION
# ================================================
# Change this to a secure password
ADMIN_PASSWORD=your_secure_admin_password_here

# ================================================
# DATABASE (Supabase PostgreSQL)
# ================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@db.supabaseproject.com:5432/postgres

# For production with self-signed certificates
DB_SSL_REJECT_UNAUTHORIZED=false

# ================================================
# AUTHENTICATION & SECURITY
# ================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_jwt_secret_here

# ================================================
# REDIS (For caching and real-time)
# ================================================
# Examples:
# - Upstash: redis://default:password@host.upstash.io:port
# - Heroku: redis://default:password@host.redisdb.com:port
# - Self-hosted: redis://username:password@localhost:6379

REDIS_URL=redis://default:password@host.upstash.io:port

# For TLS/SSL connections (Upstash, etc)
REDIS_TLS=true

# ================================================
# PAYMENT PROCESSING (Paystack)
# ================================================
# Get from: https://dashboard.paystack.co/settings/api

PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# ================================================
# EMAIL/SMTP (For verification emails)
# ================================================
# Email service examples:
# - SendGrid: smtp.sendgrid.net:587
# - Gmail: smtp.gmail.com:587 (App password required)
# - Brevo: smtp-relay.brevo.com:587

EMAIL_USER=your_email@domain.com
EMAIL_PASS=your_email_password_or_token
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587

# Optional: From address for emails
EMAIL_FROM=noreply@yaard.app
EMAIL_FROM_NAME=Yaard

# ================================================
# CLOUDINARY (For image/video hosting)
# ================================================
# Get from: https://cloudinary.com/console/settings/security

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================================
# APPLICATION SETTINGS
# ================================================
# Your app's public URL
APP_URL=https://yaardserver.netlify.app

# Node environment
NODE_ENV=production

# ================================================
# OPTIONAL: Monitoring & Logging
# ================================================
# Sentry error tracking (optional)
SENTRY_DSN=https://key@sentry.io/project-id

# ================================================
# OPTIONAL: Analytics
# ================================================
# Google Analytics, Mixpanel, etc
ANALYTICS_KEY=your_analytics_key

# ================================================
# NOTES
# ================================================
# 1. Generate secure random strings:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. For JWT_SECRET, use at least 32 random characters
#
# 3. For PAYSTACK keys:
#    - Get from https://dashboard.paystack.co/settings/api
#    - Use LIVE keys for production
#    - Keep SECRET_KEY confidential
#
# 4. For Email/SMTP:
#    - Gmail: Enable "Less secure apps" or use App Password
#    - SendGrid: Generate API key
#    - Brevo: Get SMTP credentials
#
# 5. Netlify deployment:
#    - Add these in: Site Settings → Build & deploy → Environment
#    - Or use: netlify env:set KEY VALUE
#
# 6. Testing environment variables locally:
#    - Create .env file with these (add to .gitignore)
#    - run: netlify dev
